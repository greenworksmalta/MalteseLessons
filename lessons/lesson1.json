      "passage": {
        "title": "Reading practice — A Mosta morning",
        "lines": [
          {"mt": "Bdiet ġurnata sabiħa fil-Mosta.", "en": "A nice day started in Mosta."},
          {"mt": "Marija qamet kmieni u fetħet it-tieqa.", "en": "Marija got up early and opened the window."},
          {"mt": "Hi rat ix-xemx u semgħet l-għasafar ikantaw.", "en": "She saw the sun and heard the birds singing."},
          {"mt": "Daħlet ġol-kċina u għamlet il-kafè.", "en": "She went into the kitchen and made coffee."},
          {"mt": "Wara ħarġet biex tixtri l-ħobż mill-furnar.", "en": "Then she went out to buy bread from the baker."},
          {"mt": "Fit-triq iltaqgħet ma' Tom u qaltlu Bonġu.", "en": "On the street she met Tom and said Bonġu to him."},
          {"mt": "Kienet ġurnata sabiħa biex titgħallem il-Malti.", "en": "It was a fine day to learn Maltese."}
        ]
      }
