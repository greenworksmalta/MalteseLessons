          "title": "Exercise — Conjugate għajjat (to shout)",
          "instructions": "Pick the correct present-tense form for each pronoun.",
          "choices": ["ngħajjat", "tgħajjat", "jgħajjat", "tgħajjat", "ngħajjtu", "tgħajjtu", "jgħajjtu"],
          "items": [
            {"pronoun": "Jiena", "en": "I shout", "answer": "ngħajjat"},
            {"pronoun": "Inti", "en": "You shout", "answer": "tgħajjat"},
            {"pronoun": "Huwa", "en": "He shouts", "answer": "jgħajjat"},
            {"pronoun": "Hija", "en": "She shouts", "answer": "tgħajjat"},
            {"pronoun": "Aħna", "en": "We shout", "answer": "ngħajjtu"},
            {"pronoun": "Intom", "en": "You (pl) shout", "answer": "tgħajjtu"},
            {"pronoun": "Huma", "en": "They shout", "answer": "jgħajjtu"}
          ]
        },
        {
          "id": "ex6",
          "title": "Exercise — Fill in the present tense",
          "instructions": "Choose the right form to complete each sentence.",
          "choices": ["jiftaħ", "tagħġen", "noqogħdu", "nilgħab", "tisma'", "jagħmlu"],
          "items": [
            {"sentence": "Hu ___ il-bieb fil-għodu.", "en": "He opens the door in the morning. (iftaħ)", "answer": "jiftaħ"},
            {"sentence": "Hi ___ l-għaġina għall-ftira.", "en": "She kneads the dough for the bread. (għaġen)", "answer": "tagħġen"},
            {"sentence": "Aħna ___ id-dar wara x-xogħol.", "en": "We stay home after work. (oqgħod)", "answer": "noqogħdu"},
            {"sentence": "Jien ___ il-mużika.", "en": "I play music. (lagħab)", "answer": "nilgħab"},
            {"sentence": "Int ___ ir-radju kuljum?", "en": "Do you listen to the radio every day? (sema')", "answer": "tisma'"},
            {"sentence": "Huma ___ il-pizza għall-wikkien.", "en": "They make pizza for dinner. (għamel)", "answer": "jagħmlu"}
          ]
        }
      ]
