        "lines": [
          {
            "mt": "Sar il-ħin.",
            "en": "It was time."
          },
          {
            "mt": "Daqq l-arloġġ.",
            "en": "The clock rang."
          },
          {
            "mt": "Bdiet ġurnata oħra.",
            "en": "A new day started."
          },
          {
            "mt": "Qomt mis-sodda, ilbist il-flokk u l-qalziet.",
            "en": "I got out of bed, put on my T-shirt and trousers."
          },
          {
            "mt": "Mort nieħu l-kolazzjon.",
            "en": "I went to have breakfast."
          },
          {
            "mt": "Kilt biċċa ħobż u xrobt kikkra kafè.",
            "en": "I ate a piece of bread and drank a cup of coffee."
          },
          {
            "mt": "Ħriġt mid-dar u sakkart il-bieb biċ-ċavetta.",
            "en": "I walked out of the house and locked the door with the key."
          },
          {
            "mt": "Mort nistenna x-xarabank.",
            "en": "I went to wait for the bus."
          }
