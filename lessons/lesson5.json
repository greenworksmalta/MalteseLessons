    {
      "id": "present",
      "icon": "🔁",
      "title": "Present tense",
      "subtitle": "Il-Preżent — adding a prefix to the imperative",
      "intro": "Add a prefix to the imperative to form the present tense. If the imperative starts with a vowel: n / t / j / t. If it starts with a consonant: in / t / i / t.",
      "rules": [
        {"id": "vowel", "title": "Imperative starts with a vowel — e.g. iftaħ (open!)", "rows": [
          {"person": "Jien (I)", "prefix": "n", "form": "niftaħ", "en": "I open"},
          {"person": "Int (you)", "prefix": "t", "form": "tiftaħ", "en": "you open"},
          {"person": "Hu (he)", "prefix": "j", "form": "jiftaħ", "en": "he opens"},
          {"person": "Hi (she)", "prefix": "t", "form": "tiftaħ", "en": "she opens"},
          {"person": "Aħna (we)", "prefix": "n", "form": "niftħu", "en": "we open"},
          {"person": "Intom (you pl)", "prefix": "t", "form": "tiftħu", "en": "you (pl) open"},
          {"person": "Huma (they)", "prefix": "j", "form": "jiftħu", "en": "they open"}
        ]},
        {"id": "consonant", "title": "Imperative starts with a consonant — e.g. ġib (bring!)", "rows": [
          {"person": "Jien (I)", "prefix": "in", "form": "inġib", "en": "I bring"},
          {"person": "Int (you)", "prefix": "t", "form": "iġġib", "en": "you bring"},
          {"person": "Hu (he)", "prefix": "i", "form": "iġib", "en": "he brings"},
          {"person": "Hi (she)", "prefix": "t", "form": "iġġib", "en": "she brings"},
          {"person": "Aħna (we)", "prefix": "in", "form": "inġibu", "en": "we bring"},
          {"person": "Intom (you pl)", "prefix": "t", "form": "iġġibu", "en": "you (pl) bring"},
          {"person": "Huma (they)", "prefix": "i", "form": "iġibu", "en": "they bring"}
        ]}
      ],
