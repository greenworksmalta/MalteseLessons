    {
      "id": "possessive",
      "icon": "🏷️",
      "title": "Possessive",
      "subtitle": "Il-Possessiv — using ta' to show ownership",
      "intro": "We use 'ta'' (of) to show possession. The structure is: thing + ta' + person. Example: Il-kelb ta' Matthew = Matthew's dog.",
      "examples": [
        {
          "phrase": "Il-kelb ta' Matthew",
          "en": "Matthew's dog"
        },
        {
          "phrase": "Il-pupa ta' Sarah",
          "en": "Sarah's doll"
        },
        {
          "phrase": "Il-ktieb ta' Sean",
          "en": "Sean's book"
        },
        {
          "phrase": "Il-basket ta' Maria",
          "en": "Maria's bag"
        },
        {
          "phrase": "Ir-rota ta' Jessica",
          "en": "Jessica's bike"
        },
        {
          "phrase": "Il-libsa ta' Maria",
          "en": "Maria's dress"
        },
        {
          "phrase": "L-arloġġ ta' Kevin",
          "en": "Kevin's watch"
        },
        {
          "phrase": "L-umbrella ta' Mike",
          "en": "Mike's umbrella"
        },
        {
          "phrase": "Il-flokk ta' Jake",
          "en": "Jake's t-shirt"
        },
        {
          "phrase": "It-tfal ta' Marika",
          "en": "Marika's children"
        }
      ],
