      "dialogue": [
        {"mt": "Skużani — fejn hi l-ispiżerija l-aktar viċin?", "en": "Excuse me — where's the nearest pharmacy?"},
        {"mt": "Bonġu. Imxi sal-pjazza, dur fuq ix-xellug.", "en": "Good morning. Walk to the square, turn left."},
        {"mt": "U mbagħad?", "en": "And then?"},
        {"mt": "Hemmhekk taraha faċċata ta' bank.", "en": "There you'll see it opposite a bank."},
        {"mt": "Grazzi ħafna!", "en": "Thank you very much!"}
