    {
      "id": "grammar",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "L-artiklu — The Article (the)",
      "intro": "In Maltese, the word for 'the' changes depending on the first letter of the next word. There are three rules.",
      "rules": [
        {
          "id": "moon",
          "title": "Moon consonants → il-",
          "explanation": "When the word starts with one of these consonants, use il-.",
          "letters": [
            "b",
            "f",
            "ġ",
            "g",
            "ħ",
            "j",
            "k",
            "l",
            "m",
            "p",
            "q",
            "v",
            "w"
          ],
          "examples": [
            {
              "word": "bieb",
              "article": "il-",
              "full": "il-bieb",
              "en": "the door"
            },
            {
              "word": "ġakketta",
              "article": "il-",
              "full": "il-ġakketta",
              "en": "the jacket"
            },
            {
              "word": "ħobż",
              "article": "il-",
              "full": "il-ħobż",
              "en": "the bread"
            },
            {
              "word": "kejk",
              "article": "il-",
              "full": "il-kejk",
              "en": "the cake"
            },
            {
              "word": "qamar",
              "article": "il-",
              "full": "il-qamar",
              "en": "the moon"
            }
          ]
        },
        {
          "id": "vowels",
          "title": "Vowels, h, għ → l-",
          "explanation": "Before a vowel, h, or għ, just use l-.",
          "letters": [
            "a",
            "e",
            "i",
            "o",
            "u",
            "ie",
            "h",
            "għ"
          ],
          "examples": [
            {
              "word": "ajruplan",
              "article": "l-",
              "full": "l-ajruplan",
              "en": "the airplane"
            },
            {
              "word": "elmu",
              "article": "l-",
              "full": "l-elmu",
              "en": "the helmet"
            },
            {
              "word": "ors",
              "article": "l-",
              "full": "l-ors",
              "en": "the bear"
            },
            {
              "word": "umbrella",
              "article": "l-",
              "full": "l-umbrella",
              "en": "the umbrella"
            },
            {
              "word": "għasfur",
              "article": "l-",
              "full": "l-għasfur",
              "en": "the bird"
            },
            {
              "word": "hena",
              "article": "l-",
              "full": "l-hena",
              "en": "the joy"
            }
          ]
        },
        {
          "id": "sun",
          "title": "Sun consonants → matches first letter",
          "explanation": "When the word starts with a sun consonant, the l of the article changes to match that letter.",
          "letters": [
            "ċ",
