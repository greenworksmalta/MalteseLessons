    {
      "id": "particles",
      "icon": "🔗",
      "title": "Particles",
      "subtitle": "Il-Partiċelli — small linking words",
      "intro": "Particles are small words that show a relationship between others — 'with', 'of', 'in', 'until'. Used on their own (without the article).",
      "items": [
        {"mt": "ma'", "en": "with (someone)"},
        {"mt": "ta'", "en": "of"},
        {"mt": "sa", "en": "until / as far as"},
        {"mt": "ġo", "en": "in"},
        {"mt": "bi", "en": "with"},
        {"mt": "fi", "en": "in"},
        {"mt": "lil", "en": "to (someone)"},
        {"mt": "bħal", "en": "like"},
        {"mt": "għal", "en": "for"},
        {"mt": "minn", "en": "from"},
        {"mt": "u", "en": "and"}
      ],
      "examples": [
        {"phrase": "Sara mxiet ma' Tom", "en": "Sara walked with Tom"},
        {"phrase": "Il-fjuri ta' nanna", "en": "Grandma's flowers"},
        {"phrase": "Stennejt sa nofsinhar", "en": "I waited until noon"},
        {"phrase": "Pinġejt bi pinna ħamra", "en": "I drew with a red pen"},
        {"phrase": "Marija toqgħod ġo villaġġ żgħir", "en": "Marija lives in a small village"},
        {"phrase": "Tom u Sara saru ħbieb", "en": "Tom and Sara became friends"}
      ],
      "exercises": [
        {
          "id": "ex7",
          "title": "Pick the right particle",
          "instructions": "Choose the particle that fits.",
          "choices": ["ma'", "ta'", "sa", "ġo", "bi", "fi", "lil", "bħal", "għal", "minn", "u"],
          "items": [
            {"sentence": "Sara ___ Tom marru s-suq.", "en": "Sara and Tom went to the market", "answer": "u"},
            {"sentence": "Dik il-borża ___ tagħha.", "en": "That bag is like hers", "answer": "bħal"},
            {"sentence": "Ix-xemx ___ Awwissu sħuna.", "en": "The August sun is hot", "answer": "ta'"},
            {"sentence": "Stennejt ___ tlieta.", "en": "I waited until three", "answer": "sa"},
            {"sentence": "Pinġejt il-mappa ___ ftit pinen.", "en": "I drew the map with a few pens", "answer": "bi"},
            {"sentence": "Toqgħod ___ villaġġ kwiet.", "en": "She lives in a quiet village", "answer": "fi"},
            {"sentence": "Marja marret il-Belt ___ ommha.", "en": "Marja went to Valletta with her mother", "answer": "ma'"},
            {"sentence": "Hu jħobb ___ kelb tiegħu.", "en": "He loves his dog", "answer": "lil"}
          ]
        }
      ]
    }
