{
  "id": "lesson2",
  "title": "Lesson 2 — Describing Things",
  "subtitle": "Colours, adjectives, numbers 1–30, months",
  "sections": [
    {
      "id": "serquni",
      "icon": "🆘",
      "title": "Lost & Found",
      "subtitle": "Telefonajt il-pulizija — describing what someone looks like",
      "vocab": [
        {"mt": "Skużani", "en": "Excuse me / Sorry"},
        {"mt": "Tlift il-portmoni tiegħi", "en": "I lost my wallet"},
        {"mt": "Fejn?", "en": "Where?"},
        {"mt": "Hawn fil-pjazza", "en": "Here in the square"},
        {"mt": "Iddeskrivih", "en": "Describe him"},
        {"mt": "Iddeskriviha", "en": "Describe her"},
        {"mt": "Raġel", "en": "Man"},
        {"mt": "Mara", "en": "Woman"},
        {"mt": "Tifel", "en": "Boy"},
        {"mt": "Tifla", "en": "Girl"},
        {"mt": "Twil", "en": "Tall (m)"},
        {"mt": "Twila", "en": "Tall (f)"},
        {"mt": "Qasir", "en": "Short (m)"},
        {"mt": "Qasira", "en": "Short (f)"},
        {"mt": "Bjond", "en": "Blond (m)"},
        {"mt": "Bjonda", "en": "Blond (f)"},
        {"mt": "Iswed", "en": "Dark / black-haired (m)"},
        {"mt": "Sewda", "en": "Dark / black-haired (f)"},
        {"mt": "Wieħed wieħed tnejn", "en": "One one two (police number)"},
        {"mt": "Grazzi ħafna", "en": "Thank you very much"}
      ],
      "dialogue": [
        {"mt": "Skużani — tista' tgħinni? Tlift il-portmoni tiegħi.", "en": "Excuse me — can you help me? I lost my wallet."},
        {"mt": "Mela. Fejn rajtu l-aħħar?", "en": "Of course. Where did you last see it?"},
        {"mt": "Hawn fil-pjazza, ħdejn il-kafetterija.", "en": "Here in the square, by the café."},
        {"mt": "Rajt lil xi ħadd qribu?", "en": "Did you see anyone near it?"},
        {"mt": "Iva — tifel twil, bil-flokk aħmar.", "en": "Yes — a tall boy, with a red T-shirt."},
        {"mt": "Mela ċempel il-pulizija: wieħed wieħed tnejn.", "en": "Then call the police: one-one-two."},
        {"mt": "Grazzi ħafna għall-għajnuna.", "en": "Thank you very much for the help."}
      ]
    },
