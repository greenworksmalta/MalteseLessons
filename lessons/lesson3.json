      "id": "pronouns",
      "icon": "👥",
      "title": "Pronouns",
      "subtitle": "Pronomi Personali — I, you, he, she, we…",
      "intro": "Pronouns replace nouns. Most have a long form and a short form (e.g. Jien / Jiena both mean 'I'). Use whichever feels natural.",
      "items": [
        {"mt": "Jien", "alt": "Jiena", "en": "I"},
        {"mt": "Int", "alt": "Inti", "en": "You (singular)"},
        {"mt": "Hu", "alt": "Huwa", "en": "He"},
        {"mt": "Hi", "alt": "Hija", "en": "She"},
        {"mt": "Aħna", "alt": "Aħna", "en": "We"},
        {"mt": "Intom", "alt": "Intom", "en": "You (plural)"},
        {"mt": "Huma", "alt": "Huma", "en": "They"}
      ],
      "dialogue": [
        {"mt": "Jien naqra ktieb kuljum.", "en": "I read a book every day."},
        {"mt": "Int taqra ħafna?", "en": "Do you read a lot?"},
        {"mt": "Hu jaħdem fl-uffiċċju.", "en": "He works at the office."},
        {"mt": "Hi ssajjar għaġin.", "en": "She is cooking pasta."},
        {"mt": "Aħna nimxu fil-ġnien.", "en": "We are walking in the garden."},
        {"mt": "Intom titkellmu bil-Malti?", "en": "Do you (pl) speak Maltese?"},
        {"mt": "Huma ġejjin Malta.", "en": "They are coming to Malta."}
      ],
      "exercises": [
        {
          "id": "ex1",
          "title": "Replace the noun with the right pronoun",
          "instructions": "Tap which pronoun replaces the underlined noun.",
          "choices": ["Hu", "Hi", "Huma", "Aħna", "Int"],
          "items": [
            {"sentence": "Sara taqra ktieb.", "en": "Sara is reading a book.", "answer": "Hi"},
            {"sentence": "Tom jaħdem fil-belt.", "en": "Tom works in the city.", "answer": "Hu"},
            {"sentence": "It-turisti jħobbu lill-Malta.", "en": "The tourists love Malta.", "answer": "Huma"},
            {"sentence": "Il-ġnien sabiħ ħafna.", "en": "The garden is very beautiful.", "answer": "Hu"},
            {"sentence": "Ommi qed issajjar.", "en": "My mother is cooking.", "answer": "Hi"},
            {"sentence": "Il-kotba kollha mqattajn.", "en": "The books are all torn.", "answer": "Huma"},
            {"sentence": "It-triq tkissret bix-xita.", "en": "The street was broken up by the rain.", "answer": "Hi"},
            {"sentence": "Jien u ommi noħorġu wara nofsinhar.", "en": "My mother and I go out in the afternoon.", "answer": "Aħna"},
            {"sentence": "It-tfal qed jistudjaw.", "en": "The children are studying.", "answer": "Huma"},
            {"sentence": "Maria, kif kienet il-vaganza?", "en": "Maria, how was the holiday?", "answer": "Int"}
          ]
        }
      ]
    },
