      "id": "ghpresent",
      "icon": "🅖",
      "title": "Present with għ",
      "subtitle": "Verbi bl-għ fil-preżent — special model verbs",
      "intro": "Verbs that contain the silent letter għ follow special patterns. If għ is at the beginning, follow the model 'Rifes'. If għ is in the middle, follow the model 'seRaq'.",
      "rules": [
        {"id": "ghbeg", "title": "Għ at the beginning — model Rifes (e.g. għajjat / to shout)", "rows": [
          {"pronoun": "Jiena", "model": "niRfes", "form": "ngħajjat", "en": "I shout"},
          {"pronoun": "Inti", "model": "tiRfes", "form": "tgħajjat", "en": "you shout"},
          {"pronoun": "Huwa", "model": "jiRfes", "form": "jgħajjat", "en": "he shouts"},
          {"pronoun": "Hija", "model": "tiRfes", "form": "tgħajjat", "en": "she shouts"},
          {"pronoun": "Aħna", "model": "niRfsu", "form": "ngħajjtu", "en": "we shout"},
          {"pronoun": "Intom", "model": "tiRfsu", "form": "tgħajjtu", "en": "you (pl) shout"},
          {"pronoun": "Huma", "model": "jiRfsu", "form": "jgħajjtu", "en": "they shout"}
        ]},
        {"id": "ghmid", "title": "Għ in the middle — model seRaq (e.g. nagħġa → naħlef / to swear)", "rows": [
          {"pronoun": "Jiena", "model": "nisRaq", "form": "naħlef", "en": "I swear / pledge"},
          {"pronoun": "Inti", "model": "tisRaq", "form": "taħlef", "en": "you swear"},
          {"pronoun": "Huwa", "model": "jisRaq", "form": "jaħlef", "en": "he swears"},
          {"pronoun": "Hija", "model": "tisRaq", "form": "taħlef", "en": "she swears"},
          {"pronoun": "Aħna", "model": "nisiRqu", "form": "naħilfu", "en": "we swear"},
          {"pronoun": "Intom", "model": "tisiRqu", "form": "taħilfu", "en": "you (pl) swear"},
          {"pronoun": "Huma", "model": "jisiRqu", "form": "jaħilfu", "en": "they swear"}
        ]}
      ],
