      "intro": "En maltés, la palabra para 'el / la' cambia según la primera letra de la palabra siguiente. Hay tres reglas.",
      "rules": [
        {
          "id": "moon",
          "title": "Consonantes lunares → il-",
          "explanation": "Cuando la palabra empieza con una de estas consonantes, usa il-.",
          "letters": ["b", "f", "ġ", "g", "ħ", "j", "k", "l", "m", "p", "q", "v", "w"],
          "examples": [
