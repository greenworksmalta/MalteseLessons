    {
      "id": "particles",
      "icon": "🔗",
      "title": "Particles",
      "subtitle": "Il-Partiċelli — small linking words",
      "intro": "Particles are small words that show a relationship between other words — like 'with', 'of', 'in', 'until'. Used on their own (without the article).",
      "items": [
        {
          "mt": "ma'",
          "en": "with (someone)"
        },
        {
          "mt": "ta'",
          "en": "of"
        },
        {
          "mt": "sa",
          "en": "until / as far as"
        },
        {
          "mt": "ġo",
          "en": "in"
        },
        {
          "mt": "bi",
          "en": "with"
        },
        {
          "mt": "fi",
          "en": "in"
        },
        {
          "mt": "lil",
          "en": "to"
        },
        {
          "mt": "bħal",
          "en": "like"
        },
        {
          "mt": "għal",
          "en": "for"
        },
        {
          "mt": "minn",
          "en": "from"
        },
        {
          "mt": "u",
          "en": "and"
        }
      ],
      "examples": [
        {
          "phrase": "Ġorġ mar il-Belt ma' Ġanni",
          "en": "Ġorġ went to Valletta with Ġanni"
        },
        {
          "phrase": "Mark libes iż-żarbun ta' Sean",
          "en": "Mark wore Sean's shoe"
        },
        {
          "phrase": "Jane kienet hawn sa ftit ilu",
          "en": "Jane was here until a few moments ago"
        },
        {
          "phrase": "In-nanna poġġiet l-għaġin ġo platt",
          "en": "Grandma put the pasta in the plate"
        },
        {
          "phrase": "Bi ftit ingredjenti sajjart ikla tajba",
          "en": "With a few ingredients I cooked good food"
        },
        {
          "phrase": "Mark u Marija ħarġu",
          "en": "Mark and Maria went out"
        }
      ],
      "exercises": [
        {
          "id": "ex7",
          "title": "Pick the right particle",
          "instructions": "Choose the particle that makes the sentence work.",
          "choices": [
            "ma'",
            "ta'",
            "sa",
            "ġo",
            "bi",
            "fi",
            "lil",
            "bħal",
            "għal",
            "minn",
            "u"
          ],
          "items": [
            {
              "sentence": "Jiena ___ oħti morna vaganza",
              "en": "My sister and I went on holiday",
              "answer": "u"
            },
            {
              "sentence": "Dak il-kelb ___ tiegħi",
              "en": "That dog is like mine",
              "answer": "bħal"
            },
            {
              "sentence": "Jien ilbist il-buz ___ ħija",
              "en": "I wore my brother's boots",
              "answer": "ta'"
            },
            {
              "sentence": "Jien kont hemm ___ ftit ilu",
              "en": "I was there until a moment ago",
              "answer": "sa"
            },
            {
              "sentence": "Pinġejt din l-istampa ___ ftit kuluri",
              "en": "I drew this picture with a few colours",
              "answer": "bi"
            },
            {
              "sentence": "Kien hemm raġel ___ vann",
              "en": "There was a man in a van",
              "answer": "ġo"
            },
            {
              "sentence": "Luigi mar vaganza ___ Rachel",
              "en": "Luigi went on holiday with Rachel",
              "answer": "ma'"
            },
            {
              "sentence": "Hi tħobb ___ kulħadd",
              "en": "She loves everyone",
              "answer": "lil"
            }
          ]
        }
      ]
    }
