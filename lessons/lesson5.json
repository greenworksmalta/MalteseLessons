    {
      "id": "present",
      "icon": "🔁",
      "title": "Present tense",
      "subtitle": "Il-Preżent — forming the present from the imperative",
      "intro": "Add a prefix to the imperative to form the present. If the imperative starts with a vowel, use n / t / j / t. If it starts with a consonant, use in / t / i / t.",
      "rules": [
        {"id": "vowel", "title": "Imperative starts with a vowel — e.g. oħroġ", "rows": [
          {"person": "Jien (I)", "prefix": "n", "form": "noħroġ", "en": "I go out"},
          {"person": "Int (you)", "prefix": "t", "form": "toħroġ", "en": "you go out"},
          {"person": "Hu (he)", "prefix": "j", "form": "joħroġ", "en": "he goes out"},
          {"person": "Hi (she)", "prefix": "t", "form": "toħroġ", "en": "she goes out"},
          {"person": "Aħna (we)", "prefix": "n", "form": "noħorġu", "en": "we go out"},
          {"person": "Intom (you pl)", "prefix": "t", "form": "toħorġu", "en": "you (pl) go out"},
          {"person": "Huma (they)", "prefix": "j", "form": "joħorġu", "en": "they go out"}
        ]},
        {"id": "consonant", "title": "Imperative starts with a consonant — e.g. poġġi", "rows": [
          {"person": "Jien (I)", "prefix": "in/n", "form": "npoġġi", "en": "I sit"},
          {"person": "Int (you)", "prefix": "t", "form": "tpoġġi", "en": "you sit"},
          {"person": "Hu (he)", "prefix": "i/j", "form": "jpoġġi", "en": "he sits"},
          {"person": "Hi (she)", "prefix": "t", "form": "tpoġġi", "en": "she sits"},
          {"person": "Aħna (we)", "prefix": "in/n", "form": "npoġġu", "en": "we sit"},
          {"person": "Intom (you pl)", "prefix": "t", "form": "tpoġġu", "en": "you (pl) sit"},
          {"person": "Huma (they)", "prefix": "i/j", "form": "jpoġġu", "en": "they sit"}
        ]}
      ],
