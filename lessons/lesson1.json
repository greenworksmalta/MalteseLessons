        {"mt": "X'taħdem?", "en": "What is your work?"},
        {"mt": "Jien naħdem", "en": "I work"},
        {"mt": "Kemm ilek hawn?", "en": "How long have you been here?"},
        {"mt": "Kif int?", "en": "How are you?"},
        {"mt": "Tajjeb, grazzi", "en": "Well, thanks"},
