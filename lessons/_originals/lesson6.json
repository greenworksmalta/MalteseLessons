      "passage": {
        "title": "Read and answer",
        "lines": [
          {
            "mt": "It-Tnejn filgħaxija, Mark u Maria marru jilagħbu ġol-ġnien.",
            "en": "On Monday evening, Mark and Maria went to play in the garden."
          },
          {
            "mt": "Huma bdew jilagħbu futbol bil-ballun ta' Mark.",
            "en": "They started playing football with Mark's ball."
          },
          {
            "mt": "F'daqqa waħda, Mark ixxuttja l-ballun bis-saħħa u kisser bozza.",
            "en": "All of a sudden, Mark kicked the ball hard and broke a light bulb."
          },
          {
            "mt": "It-tfal beżgħu u telqu jiġru minn fuq il-post.",
            "en": "The children got scared and ran away from the place."
          }
        ],
        "questions": [
          {
            "q": "Fejn marru jilagħbu t-tfal?",
            "qen": "Where did the children go to play?",
            "a": "It-tfal marru jilagħbu fil-ġnien.",
            "aen": "The children went to play in the garden."
          },
          {
            "q": "Min mar jilgħab fil-ġnien?",
            "qen": "Who went to play in the garden?",
            "a": "Mark u Maria.",
            "aen": "Mark and Maria."
          },
          {
            "q": "Meta marru jilagħbu fil-ġnien?",
            "qen": "When did they go to play?",
            "a": "It-Tnejn filgħaxija.",
            "aen": "On Monday evening."
          },
          {
            "q": "Ta' min hu l-ballun?",
            "qen": "Whose ball is it?",
            "a": "Il-ballun hu ta' Mark.",
            "aen": "The ball is Mark's."
          }
        ]
      }
    },
