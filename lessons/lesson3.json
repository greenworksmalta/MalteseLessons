      "subtitle": "Pronomi Demonstrattivi — this, that, these, those",
      "intro": "Maltese demonstratives change with gender and number. Use 'dan/din/dawn' for things close to you, 'dak/dik/dawk' for things further away.",
      "rules": [
        {"id": "this", "title": "This / These (close)", "explanation": "Things near you — within reach.",
         "items": [
           {"mt": "Dan", "en": "This (masculine)"},
           {"mt": "Din", "en": "This (feminine)"},
           {"mt": "Dawn", "en": "These (plural)"}
         ],
         "examples": [
           {"phrase": "Dan il-ktieb", "en": "This book (m)"},
           {"phrase": "Din it-tazza", "en": "This cup (f)"},
           {"phrase": "Dawn il-fjuri", "en": "These flowers (pl)"}
         ]},
        {"id": "that", "title": "That / Those (further)", "explanation": "Things over there — out of reach.",
         "items": [
           {"mt": "Dak", "en": "That (masculine)"},
           {"mt": "Dik", "en": "That (feminine)"},
           {"mt": "Dawk", "en": "Those (plural)"}
