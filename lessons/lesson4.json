    {
      "id": "attached",
      "icon": "➕",
      "title": "Attached pronouns",
      "subtitle": "Il-pronomi mehmużin — possessive suffixes",
      "intro": "Instead of 'X tiegħi' (my X), Maltese often attaches the pronoun directly to the noun as a suffix. E.g. id-dar tiegħi → dari (my house).",
      "examples": [
        {
          "long": "id-dar tiegħi",
          "short": "dari",
          "en": "my house"
        },
        {
          "long": "id-dar tiegħek",
          "short": "darek",
          "en": "your house"
        },
        {
          "long": "id-dar tiegħu",
          "short": "daru",
          "en": "his house"
        },
        {
          "long": "id-dar tagħha",
          "short": "darha",
          "en": "her house"
        },
        {
          "long": "id-dar tagħna",
          "short": "darna",
          "en": "our house"
        },
        {
          "long": "id-dar tagħkom",
          "short": "darkom",
          "en": "your house (pl)"
        },
        {
          "long": "id-dar tagħhom",
          "short": "darhom",
          "en": "their house"
        }
      ],
