      "title": "Directions",
      "subtitle": "Direzzjonijiet — left, right, straight ahead",
      "intro": "To ask for directions, start with: 'Skużi. Tista' tgħidli fejn hi ___, jekk jogħġbok?' Then thank them with 'Grazzi.'",
      "vocab": [
        {"mt": "Skużani", "en": "Sorry / Excuse me"},
        {"mt": "Lemin", "en": "Right"},
        {"mt": "Xellug", "en": "Left"},
        {"mt": "Dur fuq il-lemin", "en": "Turn on your right"},
        {"mt": "Dur fuq ix-xellug", "en": "Turn on your left"},
        {"mt": "Kompli bi dritt", "en": "Straight ahead"},
        {"mt": "Suq", "en": "Drive (singular)"},
        {"mt": "Imxi", "en": "Walk (singular)"},
        {"mt": "Dur", "en": "Turn (singular)"},
        {"mt": "Hawn", "en": "Here"},
        {"mt": "Hemm", "en": "There"},
        {"mt": "Wara dak", "en": "After that"},
