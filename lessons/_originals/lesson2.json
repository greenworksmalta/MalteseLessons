      "dialogue": [
        {
          "mt": "Ajjut, ajjut, ajjut!",
          "en": "Help, help, help!"
        },
        {
          "mt": "Xi ġralek?",
          "en": "What happened?"
        },
        {
          "mt": "Xi ħadd seraqli l-basket.",
          "en": "Somebody stole my bag."
        },
        {
          "mt": "Rajt min kien?",
          "en": "Did you see who it was?"
        },
        {
          "mt": "Iva, raġel ta' madwar tletin sena.",
          "en": "Yes, a man about thirty years old."
        },
        {
          "mt": "Kien qasir u oħxon.",
          "en": "He was short and fat."
        },
        {
          "mt": "Taf x'kien liebes?",
          "en": "Did you see what he was wearing?"
        },
        {
          "mt": "Flokk abjad u jeans blu. Kellu beritta ħamra.",
          "en": "A white t-shirt and blue jeans. He had a red cap."
        },
        {
          "mt": "Hemm arah idur il-kantuniera.",
          "en": "Look, there he is going round the corner."
        },
        {
          "mt": "Grazzi ħabib. Ċaw.",
          "en": "Thanks, friend. Bye."
        }
      ]
    },
