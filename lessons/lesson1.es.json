      "passage": {
        "title": "Práctica de lectura — Una mañana en Mosta",
        "lines": [
          {"mt": "Bdiet ġurnata sabiħa fil-Mosta.", "en": "Empezó un día bonito en Mosta."},
          {"mt": "Marija qamet kmieni u fetħet it-tieqa.", "en": "Marija se levantó temprano y abrió la ventana."},
          {"mt": "Hi rat ix-xemx u semgħet l-għasafar ikantaw.", "en": "Vio el sol y oyó a los pájaros cantar."},
          {"mt": "Daħlet ġo l-kċina u għamlet il-kafè.", "en": "Entró a la cocina y preparó el café."},
          {"mt": "Wara ħarġet biex tixtri l-ħobż mill-furnar.", "en": "Después salió a comprar pan en la panadería."},
          {"mt": "Fit-triq iltaqgħet ma' Tom u qaltlu Bonġu.", "en": "En la calle se encontró con Tom y le dijo Bonġu."},
          {"mt": "Kien ġurnata sabiħa biex titgħallem il-Malti.", "en": "Era un día perfecto para aprender maltés."}
        ]
      }
