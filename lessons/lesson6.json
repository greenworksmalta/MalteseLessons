      "passage": {
        "title": "Read and answer",
        "lines": [
          {"mt": "Nhar il-Ħamis, Sara u Tom marru jieklu f'restorant l-Imdina.", "en": "On Thursday, Sara and Tom went to eat at a restaurant in Mdina."},
          {"mt": "Bdew bi pjatt timpana u soppa tal-armla.", "en": "They started with a plate of timpana and widow's soup."},
          {"mt": "Tom ipprova l-fenek għall-ewwel darba u tant ħa pjaċir bih.", "en": "Tom tried rabbit for the first time and enjoyed it a lot."},
          {"mt": "Wara, qassmu kannolu u talbu kafè.", "en": "Afterwards, they shared a cannolo and asked for coffee."},
          {"mt": "Il-werej qalilhom: 'Saħħa! Erġgħu lura għada.'", "en": "The waiter told them: 'Cheers! Come back tomorrow.'"}
        ],
        "questions": [
          {"q": "Fejn marru Sara u Tom?", "qen": "Where did Sara and Tom go?", "a": "Marru f'restorant l-Imdina.", "aen": "They went to a restaurant in Mdina."},
          {"q": "Min ipprova l-fenek?", "qen": "Who tried the rabbit?", "a": "Tom ipprova l-fenek.", "aen": "Tom tried the rabbit."},
          {"q": "Meta marru jieklu?", "qen": "When did they go to eat?", "a": "Marru nhar il-Ħamis.", "aen": "They went on Thursday."},
          {"q": "Xi qassmu wara?", "qen": "What did they share afterwards?", "a": "Qassmu kannolu.", "aen": "They shared a cannolo."}
        ]
      }
