        {"mt": "tagħha", "en": "su / suya (de ella)"},
        {"mt": "tagħna", "en": "nuestro / nuestra"},
        {"mt": "tagħkom", "en": "su / suyo (de ustedes)"},
        {"mt": "tagħhom", "en": "su / suyo (de ellos)"}
