    {
      "id": "grammar",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "L-artiklu — The Article (the)",
      "intro": "In Maltese, the word for 'the' changes depending on the first letter of the next word. There are three rules.",
      "rules": [
        {
          "id": "moon",
          "title": "Moon consonants → il-",
          "explanation": "When the word starts with one of these consonants, use il-.",
          "letters": ["b", "f", "ġ", "g", "ħ", "j", "k", "l", "m", "p", "q", "v", "w"],
          "examples": [
            {"word": "ktieb", "article": "il-", "full": "il-ktieb", "en": "the book"},
            {"word": "baħar", "article": "il-", "full": "il-baħar", "en": "the sea"},
            {"word": "ġnien", "article": "il-", "full": "il-ġnien", "en": "the garden"},
            {"word": "qalb", "article": "il-", "full": "il-qalb", "en": "the heart"},
            {"word": "warda", "article": "il-", "full": "il-warda", "en": "the rose"}
          ]
        },
        {
          "id": "vowels",
          "title": "Vowels, h, għ → l-",
          "explanation": "Before a vowel, h, or għ, just use l-.",
          "letters": ["a", "e", "i", "o", "u", "ie", "h", "għ"],
          "examples": [
            {"word": "art", "article": "l-", "full": "l-art", "en": "the land"},
            {"word": "ikel", "article": "l-", "full": "l-ikel", "en": "the food"},
            {"word": "omm", "article": "l-", "full": "l-omm", "en": "the mother"},
            {"word": "uffiċċju", "article": "l-", "full": "l-uffiċċju", "en": "the office"},
            {"word": "għajn", "article": "l-", "full": "l-għajn", "en": "the eye / spring"},
            {"word": "hena", "article": "l-", "full": "l-hena", "en": "the joy"}
          ]
        },
        {
          "id": "sun",
          "title": "Sun consonants → matches first letter",
          "explanation": "When the word starts with a sun consonant, the L of the article changes to match that letter.",
          "letters": ["ċ", "d", "n", "r", "s", "t", "x", "ż", "z"],
          "examples": [
            {"word": "ċans", "article": "iċ-", "full": "iċ-ċans", "en": "the chance"},
            {"word": "dar", "article": "id-", "full": "id-dar", "en": "the house"},
            {"word": "nies", "article": "in-", "full": "in-nies", "en": "the people"},
            {"word": "raġel", "article": "ir-", "full": "ir-raġel", "en": "the man"},
            {"word": "skola", "article": "is-", "full": "is-skola", "en": "the school"},
            {"word": "triq", "article": "it-", "full": "it-triq", "en": "the street"},
            {"word": "xahar", "article": "ix-", "full": "ix-xahar", "en": "the month"},
            {"word": "żmien", "article": "iż-", "full": "iż-żmien", "en": "the time"},
            {"word": "zija", "article": "iz-", "full": "iz-zija", "en": "the aunt"}
          ]
        }
      ],
