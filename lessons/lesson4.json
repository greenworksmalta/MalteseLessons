      "title": "Attached pronouns",
      "subtitle": "Il-pronomi mehmużin — suffixes",
      "intro": "Maltese has a powerful shortcut: the pronoun (my, your, his…) attaches to the noun as a suffix. So 'my house' is one word: dari.",
      "examples": [
        {"long": "missier tiegħi", "short": "missieri", "en": "my father"},
        {"long": "missier tiegħek", "short": "missierek", "en": "your father"},
        {"long": "missier tiegħu", "short": "missieru", "en": "his father"},
        {"long": "missier tagħha", "short": "missierha", "en": "her father"},
        {"long": "missier tagħna", "short": "missierna", "en": "our father"},
        {"long": "missier tagħkom", "short": "missierkom", "en": "your (pl) father"},
        {"long": "missier tagħhom", "short": "missierhom", "en": "their father"}
      ],
      "exercises": [
        {
          "id": "ex6",
          "title": "Form the attached pronoun (set 1)",
          "instructions": "What's the attached form of each phrase?",
          "choices": ["darha", "darkom", "dari", "darhom", "daru", "darna", "darek"],
          "items": [
            {"long": "dar tiegħi", "en": "my house", "answer": "dari"},
            {"long": "dar tiegħek", "en": "your house", "answer": "darek"},
            {"long": "dar tiegħu", "en": "his house", "answer": "daru"},
            {"long": "dar tagħha", "en": "her house", "answer": "darha"},
            {"long": "dar tagħna", "en": "our house", "answer": "darna"},
            {"long": "dar tagħkom", "en": "your (pl) house", "answer": "darkom"},
            {"long": "dar tagħhom", "en": "their house", "answer": "darhom"}
          ]
        },
        {
          "id": "ex7",
          "title": "Form the attached pronoun (set 2)",
          "instructions": "Pick the contracted form of each.",
          "choices": ["wiċċna", "idu", "qalbi", "snienkom", "flusek", "arthom", "ommha"],
          "items": [
            {"long": "qalb tiegħi", "en": "my heart", "answer": "qalbi"},
            {"long": "omm tagħha", "en": "her mother", "answer": "ommha"},
            {"long": "flus tiegħek", "en": "your money", "answer": "flusek"},
            {"long": "wiċċ tagħna", "en": "our face", "answer": "wiċċna"},
            {"long": "snien tagħkom", "en": "your (pl) teeth", "answer": "snienkom"},
            {"long": "art tagħhom", "en": "their land", "answer": "arthom"},
            {"long": "id tiegħu", "en": "his hand", "answer": "idu"}
          ]
        }
      ]
