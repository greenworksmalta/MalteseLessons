      "exercises": [
        {
          "id": "ex7",
          "title": "Elige la partícula correcta",
          "instructions": "Elige la partícula que encaja.",
          "choices": ["ma'", "ta'", "sa", "ġo", "bi", "fi", "lil", "bħal", "għal", "minn", "u"],
          "items": [
            {"sentence": "Sara ___ Tom marru s-suq.", "en": "Sara y Tom fueron al mercado", "answer": "u"},
            {"sentence": "Dik il-borża ___ tagħha.", "en": "Esa bolsa es como la suya", "answer": "bħal"},
            {"sentence": "Ix-xemx ___ Awwissu sħuna.", "en": "El sol de agosto está caliente", "answer": "ta'"},
            {"sentence": "Stennejt ___ tlieta.", "en": "Esperé hasta las tres", "answer": "sa"},
            {"sentence": "Pinġejt il-mappa ___ ftit pinen.", "en": "Dibujé el mapa con unas plumas", "answer": "bi"},
            {"sentence": "Toqgħod ___ villaġġ kwiet.", "en": "Vive en un pueblo tranquilo", "answer": "fi"},
            {"sentence": "Marja marret il-Belt ___ ommha.", "en": "Marja fue a Valletta con su mamá", "answer": "ma'"},
            {"sentence": "Hu jħobb ___ kelb tiegħu.", "en": "Él quiere a su perro", "answer": "lil"}
          ]
        }
      ]
