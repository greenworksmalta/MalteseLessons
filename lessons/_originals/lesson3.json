              "phrase": "Dak ir-raġel",
              "en": "That man (m)"
            },
            {
              "phrase": "Dik il-mara",
              "en": "That woman (f)"
            },
            {
              "phrase": "Dawk il-fjuri",
              "en": "Those flowers (pl)"
            }
          ]
        }
