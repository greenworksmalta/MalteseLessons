      "title": "Phrases",
      "subtitle": "Bonġu — meeting and introducing yourself",
      "vocab": [
        {"mt": "Bonġu", "en": "Good morning"},
        {"mt": "Ħelow", "en": "Hello"},
        {"mt": "Saħħa", "en": "Cheers / Bye"},
        {"mt": "Pjaċir", "en": "Pleasure (nice to meet you)"},
        {"mt": "Jiena", "en": "I am"},
        {"mt": "Jisimni", "en": "My name is"},
        {"mt": "X'jismek?", "en": "What is your name?"},
