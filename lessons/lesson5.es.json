          "items": [
            {"present": "nikteb", "imperative": "ikteb", "en": "escribir", "answer": "singular"},
            {"present": "niktbu", "imperative": "iktbu", "en": "escribir (pl)", "answer": "plural"},
            {"present": "naqra", "imperative": "aqra", "en": "leer", "answer": "singular"},
            {"present": "naqraw", "imperative": "aqraw", "en": "leer (pl)", "answer": "plural"},
            {"present": "niekol", "imperative": "iekol", "en": "comer", "answer": "singular"},
            {"present": "nieklu", "imperative": "ieklu", "en": "comer (pl)", "answer": "plural"},
