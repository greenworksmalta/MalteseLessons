      "mt": "mara"
    },
    {
      "en": "becomes:"
    },
    {
      "mt": "ma-ra"
    },
    {
      "en": "Two syllables. Easy."
    },
    {
      "mt": "raġel"
    },
    {
      "en": "becomes:"
    },
    {
      "mt": "ra-ġel"
    },
    {
      "en": "And the longer one — umbrella:"
    },
    {
      "mt": "um-brel-la"
    },
    {
      "en": "Three syllables. Boom! 💥"
    },
