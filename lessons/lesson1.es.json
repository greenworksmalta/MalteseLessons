            {"word": "ġnien", "article": "il-", "full": "il-ġnien", "en": "el jardín"},
            {"word": "qalb", "article": "il-", "full": "il-qalb", "en": "el corazón"},
            {"word": "warda", "article": "il-", "full": "il-warda", "en": "la rosa"}
          ]
        },
        {
          "id": "vowels",
          "title": "Vocales, h, għ → l-",
          "explanation": "Antes de una vocal, h o għ, simplemente usa l-.",
