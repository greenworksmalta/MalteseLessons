      "title": "Objetos Perdidos",
      "subtitle": "Telefonajt il-pulizija — describir cómo es alguien",
      "vocab": [
        {"mt": "Skużani", "en": "Disculpa / Perdón"},
        {"mt": "Tlift il-portmoni tiegħi", "en": "Perdí mi cartera"},
        {"mt": "Fejn?", "en": "¿Dónde?"},
        {"mt": "Hawn fil-pjazza", "en": "Aquí en la plaza"},
        {"mt": "Iddeskrivih", "en": "Descríbelo"},
        {"mt": "Iddeskriviha", "en": "Descríbela"},
        {"mt": "Raġel", "en": "Hombre"},
        {"mt": "Mara", "en": "Mujer"},
        {"mt": "Tifel", "en": "Niño"},
        {"mt": "Tifla", "en": "Niña"},
        {"mt": "Twil", "en": "Alto (m)"},
        {"mt": "Twila", "en": "Alta (f)"},
        {"mt": "Qasir", "en": "Bajo (m)"},
        {"mt": "Qasira", "en": "Baja (f)"},
        {"mt": "Bjond", "en": "Rubio (m)"},
        {"mt": "Bjonda", "en": "Rubia (f)"},
        {"mt": "Iswed", "en": "Moreno / pelo negro (m)"},
        {"mt": "Sewda", "en": "Morena / pelo negro (f)"},
        {"mt": "Wieħed wieħed tnejn", "en": "Uno uno dos (número de la policía)"},
        {"mt": "Grazzi ħafna", "en": "Muchas gracias"}
      ],
      "dialogue": [
        {"mt": "Skużani — tista' tgħinni? Tlift il-portmoni tiegħi.", "en": "Disculpa — ¿me puedes ayudar? Perdí mi cartera."},
        {"mt": "Mela. Fejn rajtu l-aħħar?", "en": "Claro. ¿Dónde la viste por última vez?"},
        {"mt": "Hawn fil-pjazza, ħdejn il-kafetterija.", "en": "Aquí en la plaza, junto a la cafetería."},
        {"mt": "Rajt lil xi ħadd qribu?", "en": "¿Viste a alguien cerca?"},
        {"mt": "Iva — tifel twil, bil-flokk aħmar.", "en": "Sí — un niño alto, con una playera roja."},
        {"mt": "Mela ċempel il-pulizija: wieħed wieħed tnejn.", "en": "Entonces llama a la policía: uno-uno-dos."},
        {"mt": "Grazzi ħafna għall-għajnuna.", "en": "Muchas gracias por la ayuda."}
      ]
    },
