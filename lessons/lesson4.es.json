    {
      "id": "attached",
      "icon": "➕",
      "title": "Pronombres pegados",
      "subtitle": "Il-pronomi mehmużin — sufijos",
      "intro": "El maltés tiene un atajo poderoso: el pronombre (mi, tu, su…) se pega al sustantivo como sufijo. Así 'mi casa' es una sola palabra: dari.",
      "examples": [
        {"long": "missier tiegħi", "short": "missieri", "en": "mi padre"},
        {"long": "missier tiegħek", "short": "missierek", "en": "tu padre"},
        {"long": "missier tiegħu", "short": "missieru", "en": "su padre (de él)"},
        {"long": "missier tagħha", "short": "missierha", "en": "su padre (de ella)"},
        {"long": "missier tagħna", "short": "missierna", "en": "nuestro padre"},
        {"long": "missier tagħkom", "short": "missierkom", "en": "el padre de ustedes"},
        {"long": "missier tagħhom", "short": "missierhom", "en": "el padre de ellos"}
      ],
      "exercises": [
        {
          "id": "ex6",
          "title": "Forma el pronombre pegado (juego 1)",
          "instructions": "¿Cuál es la forma pegada de cada frase?",
          "choices": ["darha", "darkom", "dari", "darhom", "daru", "darna", "darek"],
          "items": [
            {"long": "dar tiegħi", "en": "mi casa", "answer": "dari"},
            {"long": "dar tiegħek", "en": "tu casa", "answer": "darek"},
            {"long": "dar tiegħu", "en": "su casa (de él)", "answer": "daru"},
            {"long": "dar tagħha", "en": "su casa (de ella)", "answer": "darha"},
            {"long": "dar tagħna", "en": "nuestra casa", "answer": "darna"},
            {"long": "dar tagħkom", "en": "la casa de ustedes", "answer": "darkom"},
            {"long": "dar tagħhom", "en": "la casa de ellos", "answer": "darhom"}
          ]
        },
        {
          "id": "ex7",
          "title": "Forma el pronombre pegado (juego 2)",
          "instructions": "Elige la forma contraída de cada uno.",
          "choices": ["wiċċna", "idu", "qalbi", "snienkom", "flusek", "arthom", "ommha"],
          "items": [
            {"long": "qalb tiegħi", "en": "mi corazón", "answer": "qalbi"},
            {"long": "omm tagħha", "en": "su mamá (de ella)", "answer": "ommha"},
            {"long": "flus tiegħek", "en": "tu dinero", "answer": "flusek"},
            {"long": "wiċċ tagħna", "en": "nuestra cara", "answer": "wiċċna"},
            {"long": "snien tagħkom", "en": "los dientes de ustedes", "answer": "snienkom"},
            {"long": "art tagħhom", "en": "la tierra de ellos", "answer": "arthom"},
            {"long": "id tiegħu", "en": "su mano (de él)", "answer": "idu"}
          ]
        }
      ]
    }
