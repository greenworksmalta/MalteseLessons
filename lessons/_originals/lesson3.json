{
  "id": "lesson3",
  "title": "Lesson 3 — Pronouns & Pointing",
  "subtitle": "Personal pronouns, this vs that, syllable splitting",
  "sections": [
    {
      "id": "pronouns",
      "icon": "👥",
      "title": "Pronouns",
      "subtitle": "Pronomi Personali — I, you, he, she, we…",
      "intro": "Pronouns replace nouns. Most have a long form and a short form (e.g. Jien / Jiena both mean 'I').",
      "items": [
        {
          "mt": "Jien",
          "alt": "Jiena",
          "en": "I"
        },
        {
          "mt": "Int",
          "alt": "Inti",
          "en": "You (singular)"
        },
        {
          "mt": "Hu",
          "alt": "Huwa",
          "en": "He"
        },
        {
          "mt": "Hi",
          "alt": "Hija",
          "en": "She"
        },
        {
          "mt": "Aħna",
          "alt": "Aħna",
          "en": "We"
        },
        {
          "mt": "Intom",
          "alt": "Intom",
          "en": "You (plural)"
        },
        {
          "mt": "Huma",
          "alt": "Huma",
          "en": "They"
        }
      ],
      "dialogue": [
        {
          "mt": "Jien nilgħab il-futbol.",
          "en": "I play football."
        },
        {
          "mt": "Hu jaf jilgħab futbol.",
          "en": "He knows how to play football."
        },
        {
          "mt": "Hi taf tilgħab futbol.",
          "en": "She knows how to play football."
        },
        {
          "mt": "Aħna nafu nilagħbu futbol.",
          "en": "We know how to play football."
        },
        {
          "mt": "Intom tafu tilgħabu futbol?",
          "en": "Do you (pl) know how to play football?"
        },
        {
          "mt": "Huma jafu jilagħbu futbol.",
          "en": "They know how to play football."
        }
      ],
      "exercises": [
        {
          "id": "ex1",
          "title": "Replace the noun with the right pronoun",
          "instructions": "Tap which pronoun replaces the underlined noun.",
          "choices": [
            "Hu",
            "Hi",
            "Huma",
            "Aħna",
            "Int"
          ],
          "items": [
            {
              "sentence": "Jack imur il-futbol.",
              "en": "Jack goes to football.",
              "answer": "Hu"
            },
            {
              "sentence": "Julia għandha pupa.",
              "en": "Julia has a doll.",
              "answer": "Hi"
            },
            {
              "sentence": "It-tfal raqdu.",
              "en": "The children slept.",
              "answer": "Huma"
            },
            {
              "sentence": "Il-fjura safra.",
              "en": "The flower is yellow.",
              "answer": "Hi"
            },
            {
              "sentence": "Ir-raġel qasir.",
              "en": "The man is short.",
              "answer": "Hu"
            },
            {
              "sentence": "Il-karozzi sbieħ.",
              "en": "The cars are beautiful.",
              "answer": "Huma"
            },
            {
              "sentence": "L-ors kbir wisq.",
              "en": "The bear is too big.",
              "answer": "Hu"
            },
            {
              "sentence": "Il-mara u r-raġel kielu.",
              "en": "The woman and man ate.",
              "answer": "Huma"
            },
            {
              "sentence": "Jien u t-tifla pinġejna.",
              "en": "The girl and I painted.",
              "answer": "Aħna"
            },
            {
              "sentence": "Thomas, kif mort fl-eżami?",
              "en": "Thomas, how did your exam go?",
              "answer": "Int"
            }
          ]
        }
      ]
    },
    {
      "id": "demonstratives",
      "icon": "👉",
      "title": "Demonstratives",
      "subtitle": "Pronomi Demonstrattivi — this, that, these, those",
      "intro": "Maltese demonstratives change with gender and number. Use 'dan/din/dawn' for things close to you, 'dak/dik/dawk' for things further away.",
      "rules": [
        {
          "id": "this",
          "title": "This / These (close)",
          "explanation": "Things near to you.",
          "items": [
            {
              "mt": "Dan",
              "en": "This (masculine)"
            },
            {
              "mt": "Din",
              "en": "This (feminine)"
            },
            {
              "mt": "Dawn",
              "en": "These (plural)"
            }
          ],
          "examples": [
            {
              "phrase": "Dan il-bieb",
              "en": "This door (m)"
            },
            {
              "phrase": "Din iċ-ċavetta",
              "en": "This key (f)"
            },
            {
              "phrase": "Dawn it-tfal",
              "en": "These children (pl)"
            }
          ]
        },
        {
          "id": "that",
          "title": "That / Those (further)",
          "explanation": "Things further from you.",
          "items": [
